{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build PlcReader",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/PlcReader/PlcReader.csproj"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "run PlcReader",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/PlcReader/PlcReader.csproj"
      ],
      "problemMatcher": "$msCompile",
      "group": "test"
    }
  ]
}
